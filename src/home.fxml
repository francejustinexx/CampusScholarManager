<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="16" prefWidth="760" prefHeight="540" xmlns:fx="http://javafx.com/fxml" fx:controller="HomeController">
    <padding>
        <Insets top="32" right="32" bottom="32" left="32" />
    </padding>

    <children>
        <Label text="Campus Scholar Manager" style="-fx-font-size: 24px; -fx-font-weight: bold;" />
        <Label text="A JavaFX desktop app for managing scholar records with PostgreSQL." />
        <Label text="Includes multiple views, database connection, and secure environment settings." />
        <Button text="Open Records" onAction="#openRecords" prefWidth="150" />
    </children>
</VBox>
